{
  "name": "cyclecare-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "start": "expo start",
    "start:node20": "PATH=\"/opt/homebrew/opt/node@20/bin:$PATH\" expo start --clear",
    "start:tunnel": "PATH=\"/opt/homebrew/opt/node@20/bin:$PATH\" expo start --tunnel --clear",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "check:supabase": "node scripts/check-supabase.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@supabase/supabase-js": "^2.49.0",
    "expo": "^53.0.0",
    "expo-constants": "^17.0.0",
    "expo-secure-store": "^14.0.0",
    "react": "^19.0.0",
    "react-native": "^0.79.0",
    "react-native-url-polyfill": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.8.0"
  }
}
