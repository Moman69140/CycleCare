{
  "name": "cyclecare-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "start": "expo start",
    "start:node20": "PATH=\"/opt/homebrew/opt/node@20/bin:$PATH\" node node_modules/expo/bin/cli start --clear",
    "start:tunnel": "PATH=\"/opt/homebrew/opt/node@20/bin:$PATH\" node node_modules/expo/bin/cli start --tunnel --clear",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "check:supabase": "node scripts/check-supabase.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@supabase/supabase-js": "^2.49.0",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.12",
    "expo-secure-store": "~15.0.8",
    "react": "^19.1.0",
    "react-native": "^0.81.5",
    "react-native-url-polyfill": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  }
}
